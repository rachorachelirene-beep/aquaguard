CAMERA_SOURCE=rtsp
CAMERA_INDEX=0

CAMERA_WIDTH=640
CAMERA_HEIGHT=360
CAMERA_FPS=10
JPEG_QUALITY=60
STREAM_FPS=10
PROCESSING_WIDTH=640
PROCESSING_HEIGHT=360
OPENCV_THREADS=1

FLASK_HOST=0.0.0.0
FLASK_PORT=5000

CAMERA_USERNAME=your_tapo_username
CAMERA_PASSWORD=your_tapo_password
CAMERA_IP=192.168.1.100
CAMERA_STREAM_PATH=/stream2

YOLO_ENABLED=true
YOLO_MODEL_PATH=models/flood_best.pt
YOLO_CONFIDENCE=0.35
YOLO_IMAGE_SIZE=416
YOLO_FRAME_INTERVAL=8
YOLO_MAX_DETECTIONS=3
YOLO_DEVICE=cpu

MIN_LEVEL_M=0.00
MAX_LEVEL_M=3.00
NORMAL_LEVEL_M=1.00
WARNING_LEVEL_M=2.00
CRITICAL_LEVEL_M=2.50

DEFAULT_STATION_ID=1
SUPABASE_WRITE_INTERVAL=5
ALERT_COOLDOWN_SECONDS=300

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key
